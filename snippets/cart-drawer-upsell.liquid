{% comment %}
  Renders upsell products in the cart drawer.
  Source can be a collection, manual product list, or automatic recommendations.
{% endcomment %}

{%- if settings.cart_drawer_upsell_enable and cart != empty -%}
  {%- liquid
    assign upsell_limit = settings.cart_drawer_upsell_limit | default: 4
    assign upsell_source = settings.cart_drawer_upsell_source | default: 'recommendations'
    assign upsell_product_id = cart.items.last.product.id
    assign upsell_intent = settings.cart_drawer_upsell_intent | default: 'complementary'
    assign shown_count = 0
    assign use_static_upsell = false

    if upsell_source == 'collection' and settings.cart_drawer_upsell_collection != blank
      assign use_static_upsell = true
    elsif upsell_source == 'products' and settings.cart_drawer_upsell_products.count > 0
      assign use_static_upsell = true
    endif
  -%}

  {%- if use_static_upsell -%}
    {%- capture static_upsell_items -%}
      {%- if upsell_source == 'collection' -%}
        {%- for product in settings.cart_drawer_upsell_collection.products -%}
          {%- if shown_count >= upsell_limit -%}
            {%- break -%}
          {%- endif -%}

          {%- assign product_in_cart = false -%}
          {%- for item in cart.items -%}
            {%- if item.product_id == product.id -%}
              {%- assign product_in_cart = true -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if product_in_cart == false and product.available -%}
            {% render 'cart-drawer-upsell-item', product: product %}
            {%- assign shown_count = shown_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for product in settings.cart_drawer_upsell_products -%}
          {%- if shown_count >= upsell_limit -%}
            {%- break -%}
          {%- endif -%}

          {%- assign product_in_cart = false -%}
          {%- for item in cart.items -%}
            {%- if item.product_id == product.id -%}
              {%- assign product_in_cart = true -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if product_in_cart == false and product.available -%}
            {% render 'cart-drawer-upsell-item', product: product %}
            {%- assign shown_count = shown_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}

    {%- if shown_count > 0 -%}
      <div class="cart-drawer__upsell" id="CartDrawer-Upsell">
        <div class="cart-drawer-upsell">
          <h3 class="cart-drawer-upsell__heading h4">
            {{ 'sections.cart.upsell_heading' | t }}
          </h3>
          <ul class="cart-drawer-upsell__list list-unstyled" role="list">
            {{ static_upsell_items }}
          </ul>
        </div>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="cart-drawer__upsell" id="CartDrawer-Upsell">
      <cart-drawer-upsell
        class="cart-drawer-upsell-loader"
        data-url="{{ routes.product_recommendations_url }}?limit={{ upsell_limit }}&intent={{ upsell_intent }}"
        data-section-id="cart-drawer-upsell"
        data-product-id="{{ upsell_product_id }}"
      ></cart-drawer-upsell>
    </div>
  {%- endif -%}
{%- endif -%}
