{% comment %}
  Renders a cart-styled upsell slide for the cart drawer.

  Accepts:
  - product: {Object} Product Liquid object
{% endcomment %}

{%- liquid
  assign upsell_variant = product.selected_or_first_available_variant
  assign has_variant_options = false
  if product.variants.size > 1
    assign has_variant_options = true
  endif
  if upsell_variant.quantity_rule.min > 1 or upsell_variant.quantity_rule.max != null or upsell_variant.quantity_rule.increment > 1
    assign has_variant_options = true
  endif
  assign upsell_form_id = 'CartUpsell-ProductForm-' | append: product.id
-%}

<li
  id="Slide-CartDrawerUpsell-{{ product.id }}"
  class="cart-drawer-upsell__item slider__slide slideshow__slide"
>
  <div class="cart-item cart-drawer-upsell__cart-item">
    <div class="cart-item__media">
      <a href="{{ product.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
      {%- if product.featured_media -%}
        <img
          class="cart-item__image"
          src="{{ product.featured_media | image_url: width: 300 }}"
          alt="{{ product.featured_media.alt | escape }}"
          loading="lazy"
          width="150"
          height="{{ 150 | divided_by: product.featured_media.aspect_ratio | ceil }}"
        >
      {%- endif -%}
    </div>

    <div class="cart-item__details">
      <a href="{{ product.url }}" class="cart-item__name h4 break">
        {{- product.title | escape -}}
      </a>

      {%- if upsell_variant.compare_at_price > upsell_variant.price -%}
        <div class="cart-item__discounted-prices">
          <span class="visually-hidden">
            {{ 'products.product.price.regular_price' | t }}
          </span>
          <s class="cart-item__old-price product-option">
            {{- upsell_variant.compare_at_price | money -}}
          </s>
          <span class="visually-hidden">
            {{ 'products.product.price.sale_price' | t }}
          </span>
          <strong class="cart-item__final-price product-option">
            {{ upsell_variant.price | money }}
          </strong>
        </div>
      {%- else -%}
        <div class="product-option">
          {{ upsell_variant.price | money }}
        </div>
      {%- endif -%}
    </div>

    <div class="cart-drawer-upsell__action">
      {%- if has_variant_options -%}
        <a href="{{ product.url }}" class="link cart-drawer-upsell__options">
          {{- 'sections.cart.upsell_options' | t -}}
        </a>
      {%- elsif upsell_variant.available -%}
        <product-form data-section-id="{{ section.id }}">
          {%- form 'product',
            product,
            id: upsell_form_id,
            class: 'form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input type="hidden" name="id" value="{{ upsell_variant.id }}">
            <button
              type="submit"
              name="add"
              class="button button--tertiary cart-drawer-upsell__add"
              aria-label="{{ 'products.product.add_to_cart' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-plus.svg' | inline_asset_content -}}
              </span>
              {%- render 'loading-spinner' -%}
            </button>
          {%- endform -%}
        </product-form>
      {%- else -%}
        <span class="cart-drawer-upsell__sold-out caption">
          {{- 'products.product.sold_out' | t -}}
        </span>
      {%- endif -%}
    </div>
  </div>
</li>
