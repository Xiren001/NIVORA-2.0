{% doc %}
  @prompt
    Section that contains four icons next to each other and each icon has a headline underneath, and the sub headline underneath there are aligned in the middle. The icons are changeable, and you can also adjust the background color and the one on mobile preview these icons with their headlines and sub headlines are aligned under one another.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-features-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-icon-features-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-icon-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.gap }}px;
    text-align: center;
  }

  .ai-icon-features-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.item_gap }}px;
  }

  .ai-icon-features-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-features-icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-features-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-features-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-icon-features-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-icon-features-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-features-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-icon-features-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<icon-features-{{ ai_gen_id }} class="ai-icon-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-features-container-{{ ai_gen_id }}">
    <div class="ai-icon-features-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign icon_key = 'icon_' | append: i
          assign headline_key = 'headline_' | append: i
          assign subheadline_key = 'subheadline_' | append: i
          
          assign icon = block.settings[icon_key]
          assign headline = block.settings[headline_key]
          assign subheadline = block.settings[subheadline_key]
        %}
        
        <div class="ai-icon-features-item-{{ ai_gen_id }}">
          <div class="ai-icon-features-icon-wrapper-{{ ai_gen_id }}">
            {% if icon %}
              <img
                src="{{ icon | image_url: width: 200 }}"
                alt="{{ headline | escape }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-icon-features-icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if headline != blank %}
            <h3 class="ai-icon-features-headline-{{ ai_gen_id }}">{{ headline }}</h3>
          {% endif %}
          
          {% if subheadline != blank %}
            <p class="ai-icon-features-subheadline-{{ ai_gen_id }}">{{ subheadline }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</icon-features-{{ ai_gen_id }}>

<script>
  (function() {
    class IconFeatures{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    
    customElements.define('icon-features-{{ ai_gen_id }}', IconFeatures{{ ai_gen_id }});
  })();
</script>

