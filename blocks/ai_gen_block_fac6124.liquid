{% doc %}
  @prompt
    A section divide in two equal parts. on one side there's an image, on the other side there's a headline, below that, sub-headline and below that star ratings. Next to the stars you can put text, like "44,400+ Site-Wide 5 Star Reviews" make sure the tax are placed reasonably so that they're not touching the sides of the screen so they're not too wide and they are adjustable and look good whether in desktop Preview or mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-review-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-review-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: center;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_vertical }}px {{ block.settings.section_padding_horizontal }}px;
  }

  .ai-review-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-review-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-review-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-review-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-review-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-review-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-review-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    font-weight: {{ block.settings.subheadline_weight }};
    color: {{ block.settings.subheadline_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-review-rating-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.rating_gap }}px;
    flex-wrap: wrap;
  }

  .ai-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.star_spacing }}px;
  }

  .ai-review-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-review-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    font-weight: {{ block.settings.review_text_weight }};
    color: {{ block.settings.review_text_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-review-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    {% if block.settings.mobile_image_position == 'bottom' %}
      .ai-review-image-wrapper-{{ ai_gen_id }} {
        order: 2;
      }
      .ai-review-content-{{ ai_gen_id }} {
        order: 1;
      }
    {% endif %}

    .ai-review-content-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_content_padding }}px;
    }

    .ai-review-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-review-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.9 }}px;
    }

    .ai-review-star-{{ ai_gen_id }} {
      width: {{ block.settings.star_size | times: 0.8 }}px;
      height: {{ block.settings.star_size | times: 0.8 }}px;
    }

    .ai-review-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.review_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<review-section-{{ ai_gen_id }} class="ai-review-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-review-container-{{ ai_gen_id }}">
    <div class="ai-review-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-review-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-review-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-review-content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-review-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
      {% endif %}

      {% if block.settings.subheadline != blank %}
        <p class="ai-review-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
      {% endif %}

      <div class="ai-review-rating-wrapper-{{ ai_gen_id }}">
        <div class="ai-review-stars-{{ ai_gen_id }}" aria-label="5 star rating">
          {% for i in (1..5) %}
            <svg class="ai-review-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
        </div>

        {% if block.settings.review_text != blank %}
          <p class="ai-review-text-{{ ai_gen_id }}">{{ block.settings.review_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</review-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ReviewSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('review-section-{{ ai_gen_id }}', ReviewSection{{ ai_gen_id }});
  })();
</script>

