{% doc %}
  @prompt
    A section divide in two equal parts. on one side there's an image, on the other side there's a headline, below that, sub-headline and below that star ratings. Next to the stars you can put text, like "44,400+ Site-Wide 5 Star Reviews"
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-split-section__container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 40px;
    width: 100%;
  }

  .ai-split-section__image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-split-section__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-split-section__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-split-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-split-section__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-split-section__content-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-split-section__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-split-section__subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.subheadline_color }};
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .ai-split-section__rating-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-split-section__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-split-section__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-split-section__rating-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.rating_text_size }}px;
    color: {{ block.settings.rating_text_color }};
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .ai-split-section__container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: 24px;
    }
  }
{% endstyle %}

<split-section-{{ ai_gen_id }}
  class="ai-split-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-split-section__container-{{ ai_gen_id }}">
    {% if block.settings.image_position == 'left' %}
      <div class="ai-split-section__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-split-section__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-split-section__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-split-section__empty-state-{{ ai_gen_id }}">
              Next, add an image
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-split-section__content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-split-section__headline-{{ ai_gen_id }}">
          {{ block.settings.headline }}
        </h2>
      {% endif %}

      {% if block.settings.subheadline != blank %}
        <div class="ai-split-section__subheadline-{{ ai_gen_id }}">
          {{ block.settings.subheadline }}
        </div>
      {% endif %}

      <div class="ai-split-section__rating-wrapper-{{ ai_gen_id }}">
        <div class="ai-split-section__stars-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            <svg
              class="ai-split-section__star-{{ ai_gen_id }}"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
        </div>

        {% if block.settings.rating_text != blank %}
          <div class="ai-split-section__rating-text-{{ ai_gen_id }}">
            {{ block.settings.rating_text }}
          </div>
        {% endif %}
      </div>
    </div>

    {% if block.settings.image_position == 'right' %}
      <div class="ai-split-section__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-split-section__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-split-section__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-split-section__empty-state-{{ ai_gen_id }}">
              Next, add an image
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</split-section-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('split-section-{{ ai_gen_id }}', SplitSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image with reviews",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "column",
          "label": "Image on top"
        },
        {
          "value": "column-reverse",
          "label": "Content on top"
        }
      ],
      "default": "column"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "inline_richtext",
      "id": "headline",
      "label": "Headline",
      "default": "Trusted by thousands"
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Sub-headline"
    },
    {
      "type": "inline_richtext",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "Join our community of happy customers"
    },
    {
      "type": "range",
      "id": "subheadline_size",
      "label": "Size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheadline_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Star rating"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#FFD700"
    },
    {
      "type": "inline_richtext",
      "id": "rating_text",
      "label": "Rating text",
      "default": "44,400+ Site-Wide 5 Star Reviews"
    },
    {
      "type": "range",
      "id": "rating_text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "rating_text_color",
      "label": "Text color",
      "default": "#121212"
    }
  ],
  "presets": [
    {
      "name": "Image with reviews"
    }
  ]
}
{% endschema %}
