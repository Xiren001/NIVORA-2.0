{% doc %}
  @prompt
    A section that has headline underneath sub headline in the middle underneath there are four image boxes and under the images in the same boxes you can put short text. Also make sure to enable scrolling on mobile., make the image boxes have a headline and a sub-headline below them, aligned in the middle
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-image-grid-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-image-grid-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 600;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    color: {{ block.settings.headline_color }};
  }

  .ai-image-grid-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    margin: 0;
    color: {{ block.settings.subheadline_color }};
  }

  .ai-image-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-image-grid-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.box_background_color }};
    border-radius: {{ block.settings.box_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.box_shadow_opacity }});
  }

  .ai-image-grid-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-image-grid-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-grid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-grid-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-grid-content-{{ ai_gen_id }} {
    padding: {{ block.settings.text_padding }}px;
    text-align: center;
  }

  .ai-image-grid-box-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.box_headline_size }}px;
    font-weight: 600;
    margin: 0 0 {{ block.settings.box_headline_spacing }}px;
    color: {{ block.settings.box_headline_color }};
  }

  .ai-image-grid-box-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.box_subheadline_size }}px;
    margin: 0;
    color: {{ block.settings.box_subheadline_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-image-grid-container-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: {{ block.settings.mobile_gap }}px;
      padding-bottom: 10px;
    }

    .ai-image-grid-item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_item_width }}%;
      scroll-snap-align: start;
    }

    .ai-image-grid-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-image-grid-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.8 }}px;
    }

    .ai-image-grid-box-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.box_headline_size | times: 0.9 }}px;
    }

    .ai-image-grid-box-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.box_subheadline_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<image-grid-{{ ai_gen_id }} class="ai-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-grid-header-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-image-grid-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}
    {% if block.settings.subheadline != blank %}
      <p class="ai-image-grid-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
    {% endif %}
  </div>

  <div class="ai-image-grid-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign box_headline_key = 'box_headline_' | append: i
        assign box_subheadline_key = 'box_subheadline_' | append: i
        assign image = block.settings[image_key]
        assign box_headline = block.settings[box_headline_key]
        assign box_subheadline = block.settings[box_subheadline_key]
      %}

      <div class="ai-image-grid-item-{{ ai_gen_id }}">
        <div class="ai-image-grid-image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 600 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-image-grid-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-grid-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <div class="ai-image-grid-content-{{ ai_gen_id }}">
          {% if box_headline != blank %}
            <h3 class="ai-image-grid-box-headline-{{ ai_gen_id }}">{{ box_headline }}</h3>
          {% endif %}
          {% if box_subheadline != blank %}
            <p class="ai-image-grid-box-subheadline-{{ ai_gen_id }}">{{ box_subheadline }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</image-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-image-grid-container-{{ ai_gen_id }}');
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        if (!this.container) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        this.container.addEventListener('mousedown', (e) => {
          if (window.innerWidth > 749) return;
          isDown = true;
          startX = e.pageX - this.container.offsetLeft;
          scrollLeft = this.container.scrollLeft;
        });

        this.container.addEventListener('mouseleave', () => {
          isDown = false;
        });

        this.container.addEventListener('mouseup', () => {
          isDown = false;
        });

        this.container.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.container.offsetLeft;
          const walk = (x - startX) * 2;
          this.container.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('image-grid-{{ ai_gen_id }}', ImageGrid{{ ai_gen_id }});
  })();
</script>

