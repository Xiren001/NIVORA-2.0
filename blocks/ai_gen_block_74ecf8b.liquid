{% doc %}
  @prompt
    A section that has a headline below that it has a sub headline and below that it has three boxes which you can put images into and each box has a headline in the sub headline below them. Make sure that phone preview enables scroll
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-feature-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-feature-section__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-feature-section__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    font-weight: 600;
  }

  .ai-feature-section__subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.subheadline_color }};
    margin: 0;
  }

  .ai-feature-section__boxes-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.box_gap }}px;
  }

  .ai-feature-section__box-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_background_color }};
    border-radius: {{ block.settings.box_border_radius }}px;
    padding: {{ block.settings.box_padding }}px;
    text-align: {{ block.settings.box_text_alignment }};
  }

  .ai-feature-section__box-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.box_image_spacing }}px;
    border-radius: {{ block.settings.box_image_radius }}px;
    overflow: hidden;
  }

  .ai-feature-section__box-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-feature-section__box-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-section__box-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-feature-section__box-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.box_headline_size }}px;
    color: {{ block.settings.box_headline_color }};
    margin: 0 0 {{ block.settings.box_headline_spacing }}px;
    font-weight: 600;
  }

  .ai-feature-section__box-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.box_subheadline_size }}px;
    color: {{ block.settings.box_subheadline_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-feature-section__boxes-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      overflow-x: auto;
      display: flex;
      gap: {{ block.settings.box_gap }}px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }

    .ai-feature-section__box-{{ ai_gen_id }} {
      min-width: 280px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }

    .ai-feature-section__headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.8);
    }

    .ai-feature-section__subheadline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheadline_size }}px * 0.9);
    }
  }
{% endstyle %}

<feature-section-{{ ai_gen_id }} class="ai-feature-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-section__container-{{ ai_gen_id }}">
    <div class="ai-feature-section__header-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-feature-section__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
      {% endif %}
      {% if block.settings.subheadline != blank %}
        <p class="ai-feature-section__subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
      {% endif %}
    </div>

    <div class="ai-feature-section__boxes-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'box_' | append: i | append: '_image'
          assign headline_key = 'box_' | append: i | append: '_headline'
          assign subheadline_key = 'box_' | append: i | append: '_subheadline'
          
          assign box_image = block.settings[image_key]
          assign box_headline = block.settings[headline_key]
          assign box_subheadline = block.settings[subheadline_key]
        %}

        <div class="ai-feature-section__box-{{ ai_gen_id }}">
          <div class="ai-feature-section__box-image-wrapper-{{ ai_gen_id }}">
            {% if box_image %}
              <img
                src="{{ box_image | image_url: width: 800 }}"
                alt="{{ box_image.alt | escape }}"
                loading="lazy"
                width="{{ box_image.width }}"
                height="{{ box_image.height }}"
                class="ai-feature-section__box-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-feature-section__box-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if box_headline != blank %}
            <h3 class="ai-feature-section__box-headline-{{ ai_gen_id }}">{{ box_headline }}</h3>
          {% endif %}

          {% if box_subheadline != blank %}
            <p class="ai-feature-section__box-subheadline-{{ ai_gen_id }}">{{ box_subheadline }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</feature-section-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        const boxesContainer = this.querySelector('.ai-feature-section__boxes-{{ ai_gen_id }}');
        if (!boxesContainer) return;

        if (window.innerWidth <= 749) {
          boxesContainer.style.scrollBehavior = 'smooth';
        }
      }
    }

    customElements.define('feature-section-{{ ai_gen_id }}', FeatureSection{{ ai_gen_id }});
  })();
</script>

