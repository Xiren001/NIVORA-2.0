{% doc %}
  @prompt
    I want a "You May Also Like" section featuring my store's best sellers in a nice way, making my store feel like a big jewelry brand
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-you-may-like-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-you-may-like-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-you-may-like-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-you-may-like-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ai-you-may-like-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .ai-you-may-like-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-you-may-like-product-{{ ai_gen_id }} {
    text-align: center;
    transition: transform 0.3s ease;
  }

  .ai-you-may-like-product-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-you-may-like-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 16px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f9f9f9;
  }

  .ai-you-may-like-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s ease;
  }

  .ai-you-may-like-product-{{ ai_gen_id }}:hover .ai-you-may-like-image-wrapper-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-you-may-like-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-you-may-like-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-you-may-like-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .ai-you-may-like-product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-you-may-like-product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-you-may-like-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .ai-you-may-like-product-price-{{ ai_gen_id }} .price--on-sale {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-you-may-like-product-price-{{ ai_gen_id }} .price__regular {
    text-decoration: line-through;
    opacity: 0.6;
    margin-right: 8px;
  }

  .ai-you-may-like-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .ai-you-may-like-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
    }

    .ai-you-may-like-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-you-may-like-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-you-may-like-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-you-may-like-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 0 {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-you-may-like-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-you-may-like-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-you-may-like-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-you-may-like-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-you-may-like-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.product_list != blank %}
      <div class="ai-you-may-like-grid-{{ ai_gen_id }}">
        {% for product in block.settings.product_list limit: block.settings.products_to_show %}
          <div class="ai-you-may-like-product-{{ ai_gen_id }}">
            <a href="{{ product.url }}" class="ai-you-may-like-image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
                >
              {% else %}
                <div class="ai-you-may-like-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </a>

            <h3 class="ai-you-may-like-product-title-{{ ai_gen_id }}">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>

            <div class="ai-you-may-like-product-price-{{ ai_gen_id }}">
              {% if product.compare_at_price > product.price %}
                <span class="price--on-sale">{{ product.price | money }}</span>
                <span class="price__regular">{{ product.compare_at_price | money }}</span>
              {% else %}
                <span>{{ product.price | money }}</span>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-you-may-like-empty-{{ ai_gen_id }}">
        Select your best-selling products to showcase here
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "You may also like",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "You May Also Like"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Handpicked pieces from our collection"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_row_tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Products per row (tablet)",
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Grid gap",
      "default": 30
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Header spacing",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 28
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 16
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Title color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "product_price_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Price size",
      "default": 15
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Price color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Sale price color",
      "default": "#d82c0d"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "You may also like"
    }
  ]
}
{% endschema %}
